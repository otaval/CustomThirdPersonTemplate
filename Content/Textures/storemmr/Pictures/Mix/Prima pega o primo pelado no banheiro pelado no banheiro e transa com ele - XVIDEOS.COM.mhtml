.videoad-click { position: absolute; width: 100%; height: 100%; }

.videoad-nocontrol-ios::-webkit-media-controls-play-button, .videoad-nocontrol-ios::-webkit-media-controls-start-playback-button { opacity: 0; pointer-events: none; width: 5px; }

.videoad-skip { background-color: rgba(0, 0, 0, 0.6); border: 2px solid rgba(255, 255, 255, 0.35); bottom: 0px; color: rgba(255, 255, 255, 0.8); cursor: default; height: 40px; line-height: 40px; margin: 10px; max-width: calc(95% - 24px); position: absolute; right: 0px; transition: all 0.2s ease 0s; }

.videoad-skip:hover { background-color: rgb(0, 0, 0); }

.videoad-skip.skippable:hover { border-color: rgb(255, 255, 255); color: rgb(255, 255, 255); cursor: pointer; }

.videoad-skip .icon-f { vertical-align: text-bottom; }

.videoad-skip .videoad-skip-txt { display: inline-block; font-size: 18px; font-weight: 700; line-height: 18px; padding: 0px 10px; vertical-align: middle; white-space: nowrap; }

.videoad-title { background-color: rgba(0, 0, 0, 0.5); color: rgb(255, 255, 255); font-size: 16px; font-weight: 700; cursor: pointer; right: 0px; margin: 0px; padding: 10px 15px; position: absolute; text-align: left; top: 0px; transition: all 0.2s ease 0s; }

.videoad-title:hover { background-color: rgba(0, 0, 0, 0.5); }

.videoad-title-invideo { font-size: 12px; padding: 5px 10px; }

.videoad-title-txt { display: inline; }

.videoad-title-icon { height: 16px; display: inline; margin-left: 6px; margin-bottom: 3px; }

.videoad-status { vertical-align: middle; color: rgb(255, 255, 255); font-size: 12px; font-weight: 400; left: 0px; bottom: 0px; height: 100%; display: inline; }

.videoad-mute, .videoad-unmute { border-radius: 50%; bottom: 0px; cursor: pointer; display: block; height: 20px; left: 0px; margin: 8px; padding: 15px; position: absolute; width: 20px; }

.videoad-mute { animation: pulse 2s ease-out 1s 1 normal none running; box-shadow: rgba(255, 255, 255, 0.2) 0px 0px 0px; }

.videoad-mute:hover { animation: pulse 2s ease-out 0s infinite normal none running; }

.videoad-unmute { display: none; }

.muted .videoad-mute { animation: none 0s ease 0s 1 normal none running; display: none; }

.muted .videoad-unmute { display: block; }

.progress-bar-cursor { height: 100%; background-color: rgb(204, 210, 50); }

@-webkit-keyframes pulse { 
  0% { box-shadow: rgba(255, 255, 255, 0.2) 0px 0px 0px 0px; background: rgba(255, 255, 255, 0); }
  35% { background: rgba(255, 255, 255, 0.1); }
  70% { box-shadow: rgba(255, 255, 255, 0) 0px 0px 0px 10px; }
  100% { box-shadow: rgba(255, 255, 255, 0) 0px 0px 0px 0px; background: rgba(255, 255, 255, 0); }
}

@keyframes pulse { 
  0% { box-shadow: rgba(255, 255, 255, 0.2) 0px 0px 0px 0px; background: rgba(255, 255, 255, 0); }
  35% { background: rgba(255, 255, 255, 0.1); }
  70% { box-shadow: rgba(255, 255, 255, 0) 0px 0px 0px 10px; }
  100% { box-shadow: rgba(255, 255, 255, 0) 0px 0px 0px 0px; background: rgba(255, 255, 255, 0); }
}

@media (max-width: 480px) {
  .videoad-title { font-size: 18px; padding: 10px 16px; }
  .videoad-title-invideo { font-size: 12px; padding: 5px 10px; }
  .videoad-skip { height: 37px; line-height: 37px; }
  .videoad-skip-txt { font-size: 19px; line-height: 18px; }
}

@media (max-width: 360px) {
  .videoad-skip-txt { font-size: 17px; }
}

@media (max-width: 280px) {
  .videoad-skip-txt { font-size: 15px; }
}
