@charset "utf-8";

#html5video { position: relative; }

#html5video, #html5video * { box-sizing: content-box; }

#html5video.fakefullscreen { position: fixed; top: 0px; left: 0px; width: 100%; height: 100%; z-index: 400; }

#html5video .noselect { user-select: none; }

#html5video .sdabox { position: absolute; height: 235px; width: 338px; background: rgb(255, 255, 255); border: 4px solid rgb(0, 0, 0); padding: 4px; top: 5%; left: 10%; }

#html5video .sdabox .sdacontainer { position: absolute; left: 4px; top: 4px; right: 4px; bottom: 4px; }

#html5video .sdabox .sdacontainer img { width: 100%; height: 100%; }

